# Application Settings
APP_NAME=Mock MCP Server
DEBUG=false

# Web Server Settings
WEB_PORT=8000
HOST=0.0.0.0
PORT=8000

# API Key Authentication
# Name of the HTTP header callers must include with any non-empty value.
# Change this to match the header name used by the real API you are mocking.
API_KEY_HEADER=X-Api-Key

# Logging
# Standard Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
